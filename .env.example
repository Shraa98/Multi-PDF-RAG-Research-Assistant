# Copy this file to `.env` and fill in values you plan to use.

# Groq provider
GROQ_API_KEY=

# Google provider
GOOGLE_API_KEY=

# Optional provider keys (only if you use these providers)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Langfuse observability
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Ollama local endpoint
OLLAMA_BASE_URL=http://localhost:11434
